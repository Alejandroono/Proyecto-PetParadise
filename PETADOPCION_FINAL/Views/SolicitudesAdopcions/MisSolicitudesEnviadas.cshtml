@model IEnumerable<PETADOPCION_FINAL.Models.SolicitudesAdopcion>

@{
    ViewData["Title"] = "Mis Solicitudes de Adopción";

}

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<body class="bg-slate-100 font-sans py-10 px-4">

    <div class="max-w-6xl mx-auto">
        @* Encabezado Brutalista *@
        <div class="bg-[#5CA9DD] rounded-t-[2.5rem] p-8 text-white shadow-2xl flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h2 class="text-4xl font-black italic tracking-tighter flex items-center gap-3">
                    <span class="material-icons text-5xl">send</span>
                    MIS SOLICITUDES
                </h2>
                <p class="text-blue-100 text-[10px] mt-1 uppercase tracking-[0.3em] font-bold opacity-90">Rastreo de procesos de adopción en tiempo real</p>
            </div>
            <div class="bg-white/20 backdrop-blur-md px-6 py-3 rounded-2xl border border-white/30">
                <span class="text-xs font-black uppercase block opacity-70">Total Enviadas</span>
                <span class="text-2xl font-black italic">@Model?.Count() Mascotas</span>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 bg-white p-8 md:p-12 rounded-b-[2.5rem] shadow-xl border-x border-b border-slate-200">

                @foreach (var item in Model)
                {
                    <div class="group bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-2xl transition-all duration-500 overflow-hidden flex flex-col h-full hover:-translate-y-2">

                        @{
                            var foto = item.IdMascotaNavigation.MascotaFotos.FirstOrDefault(f => f.EsPrincipal == true)?.UrlFoto
                            ?? item.IdMascotaNavigation.MascotaFotos.FirstOrDefault()?.UrlFoto;
                        }

                        @* Image Header *@
                        <div class="relative h-56 overflow-hidden">
                            <img src="@(string.IsNullOrEmpty(foto) ? "/images/default-pet.png" : foto)"
                                 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />

                            @* Badge de Estado Agresivo *@
                            <div class="absolute top-4 right-4">
                                @if (item.Estado == "Pendiente")
                                {
                                    <span class="bg-amber-400 text-amber-900 text-[10px] font-black px-4 py-2 rounded-full shadow-xl border-2 border-white flex items-center gap-2">
                                        <i class="fas fa-history animate-spin-slow"></i> PENDIENTE
                                    </span>
                                }
                                else if (item.Estado == "Aprobada")
                                {
                                    <span class="bg-emerald-500 text-white text-[10px] font-black px-4 py-2 rounded-full shadow-xl border-2 border-white flex items-center gap-2">
                                        <i class="fas fa-check-double"></i> APROBADA
                                    </span>
                                }
                                else
                                {
                                    <span class="bg-rose-600 text-white text-[10px] font-black px-4 py-2 rounded-full shadow-xl border-2 border-white flex items-center gap-2">
                                        <i class="fas fa-ban"></i> RECHAZADA
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="p-6 flex flex-col flex-grow">
                            <div class="mb-4">
                                <h4 class="text-2xl font-black text-slate-800 italic tracking-tighter uppercase">@item.IdMascotaNavigation.Nombre</h4>
                                <div class="flex items-center gap-2 text-slate-400 text-[10px] font-bold uppercase mt-1">
                                    <span class="material-icons text-sm text-[#5CA9DD]">person</span>
                                    <span>@item.IdMascotaNavigation.IdUsuarioPublicadorNavigation.Nombre</span>
                                </div>
                            </div>

                            @* Tu mensaje - Estilo Terminal *@
                            <div class="bg-slate-900 rounded-2xl p-4 mb-6 relative">
                                <span class="absolute -top-2 left-4 bg-[#5CA9DD] text-white text-[8px] font-black px-2 py-0.5 rounded shadow-md uppercase">Tu Mensaje</span>
                                <p class="text-slate-300 text-xs italic leading-relaxed">"@item.Mensaje"</p>
                            </div>

                            @* Footer de la Card con el botón que recuperé *@
                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                <div class="flex flex-col">
                                    <span class="text-[8px] font-black text-slate-400 uppercase">Enviada el</span>
                                    <span class="text-xs font-bold text-slate-600">@item.FechaSolicitud?.ToString("dd/MM/yyyy")</span>
                                </div>

                             
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            @* Estado Vacío con estilo de Error Crítico *@
            <div class="bg-white p-20 rounded-b-[2.5rem] shadow-xl text-center border-x border-b border-slate-200">
                <div class="inline-block p-10 bg-slate-50 rounded-[3rem] border-4 border-dashed border-slate-200 mb-6">
                    <span class="material-icons text-slate-200 text-8xl">search_off</span>
                </div>
                <h3 class="text-3xl font-black text-slate-800 italic tracking-tighter mb-2 uppercase">No hay rastro de solicitudes</h3>
                <p class="text-slate-400 text-sm font-medium mb-8 max-w-sm mx-auto">Parece que aún no has intentado adoptar a ningún peludo. ¿Qué esperas?</p>
                <a href="@Url.Action("Index", "Mascotas")" class="inline-flex items-center gap-3 bg-[#5CA9DD] hover:bg-blue-600 text-white font-black px-10 py-5 rounded-2xl shadow-2xl transition-all active:scale-95 uppercase tracking-widest text-sm">
                    <span class="material-icons">explore</span>
                    Explorar el Catálogo
                </a>
            </div>
        }

        <p class="text-center text-slate-400 text-[10px] font-black uppercase tracking-[0.4em] mt-10 opacity-50">
            PETADOPCION SYSTEM // ENGINE V.2.6
        </p>
    </div>

    <style>
        .animate-spin-slow {
            animation: spin 3s linear infinite;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }
    </style>

</body>