@model PETADOPCION_FINAL.Models.Usuario

@{
    ViewData["Title"] = "Registro - PetParadise";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://cdn.tailwindcss.com"></script>
    @* IMPORTANTE: Sin este link los iconos no salen *@
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <title>PetParadise – Registro</title>
</head>

<body class="bg-gradient-to-r from-blue-500 via-slate-700 to-blue-800 min-h-screen flex items-center justify-center p-4">

    <div class="bg-white/10 backdrop-blur-lg rounded-3xl shadow-2xl w-full max-w-4xl overflow-hidden border border-white/20">

        <div class="md:flex">
            <div class="hidden md:flex md:w-1/3 bg-blue-600/20 p-10 flex-col justify-center items-center text-center border-r border-white/10">
                <img src="/asset/imagen.png" class="h-24 mb-6 drop-shadow-lg" />
                <h2 class="text-3xl font-bold text-white mb-4 tracking-wide">PETPARADISE</h2>
                <p class="text-blue-100 text-sm">Únete a nuestra comunidad y ayuda a transformar vidas.</p>
                <div class="mt-10 flex justify-center">
                    <img src="https://cdn.pixabay.com/photo/2017/09/25/13/12/dog-2785074_1280.jpg"
                         class="w-full max-w-sm opacity-90 rounded-3xl shadow-2xl object-cover transform hover:scale-105 transition duration-500"
                         style="border-radius: 2.5rem;" />
                </div>
            </div>

            <div class="w-full md:w-2/3 bg-white p-8 md:p-12">
                <div class="mb-8">
                    <h1 class="text-3xl font-extrabold text-gray-800">Crea tu cuenta</h1>
                    <p class="text-gray-500 mt-2">Completa el formulario para registrarte.</p>
                </div>

                <form asp-action="Create" method="post" id="registerForm" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm italic"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Nombre" class="block font-bold text-gray-700 text-sm">Nombre</label>
                            <input asp-for="Nombre" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition" placeholder="Tu nombre" />
                            <span asp-validation-for="Nombre" class="text-red-500 text-xs"></span>
                        </div>

                        <div>
                            <label asp-for="Apellido" class="block font-bold text-gray-700 text-sm">Apellido</label>
                            <input asp-for="Apellido" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition" placeholder="Tu apellido" />
                            <span asp-validation-for="Apellido" class="text-red-500 text-xs"></span>
                        </div>

                        <div class="md:col-span-2">
                            <label asp-for="Email" class="block font-bold text-gray-700 text-sm">Correo Electrónico</label>
                            <input asp-for="Email" type="email" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition" placeholder="ejemplo@gmail.com" />
                            <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                        </div>

                        @* CONTRASEÑA CON OJO *@
                        <div class="relative">
                            <label asp-for="PasswordHash" class="block font-bold text-gray-700 text-sm">Contraseña</label>
                            <div class="relative">
                                <input asp-for="PasswordHash" type="password" id="pass" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition pr-10" placeholder="********" />
                                <button type="button" onclick="togglePass('pass', 'eye1')" class="absolute right-3 top-1/2 transform -translate-y-1/2 mt-0.5 text-gray-400">
                                    <span id="eye1" class="material-icons text-xl">visibility_off</span>
                                </button>
                            </div>
                            <span asp-validation-for="PasswordHash" class="text-red-500 text-xs"></span>
                        </div>

                        @* CONFIRMAR CONTRASEÑA CON OJO *@
                        <div class="relative">
                            <label class="block font-bold text-gray-700 text-sm">Confirmar Contraseña</label>
                            <div class="relative">
                                <input type="password" id="confirmPass" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition pr-10" placeholder="********" />
                                <button type="button" onclick="togglePass('confirmPass', 'eye2')" class="absolute right-3 top-1/2 transform -translate-y-1/2 mt-0.5 text-gray-400">
                                    <span id="eye2" class="material-icons text-xl">visibility_off</span>
                                </button>
                            </div>
                            <span id="errorConfirm" class="text-red-500 text-xs font-bold"></span>
                        </div>

                        <div>
                            <label asp-for="Telefono" class="block font-bold text-gray-700 text-sm">Teléfono</label>
                            <input asp-for="Telefono" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition" placeholder="3000000000" />
                            <span asp-validation-for="Telefono" class="text-red-500 text-xs"></span>
                        </div>

                        <input type="hidden" asp-for="IdRol" value="2" />

                        <div>
                            <label asp-for="Ciudad" class="block font-bold text-gray-700 text-sm">Ciudad</label>
                            <input asp-for="Ciudad" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition" placeholder="Tu ciudad" />
                            <span asp-validation-for="Ciudad" class="text-red-500 text-xs"></span>
                        </div>

                        <div>
                            <label asp-for="Direccion" class="block font-bold text-gray-700 text-sm">Dirección</label>
                            <input asp-for="Direccion" class="w-full border border-gray-300 rounded-xl px-4 py-2 mt-1 focus:ring-2 focus:ring-blue-400 outline-none transition" placeholder="Calle/Avenida" />
                            <span asp-validation-for="Direccion" class="text-red-500 text-xs"></span>
                        </div>
                    </div>

                    <div class="pt-6">
                        <button type="submit"
                                class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 hover:scale-[1.02] transition duration-300 shadow-lg shadow-blue-200">
                            Registrarme ahora
                        </button>

                        <div class="mt-6 text-center">
                            <p class="text-sm text-gray-500">
                                ¿Ya tienes una cuenta?
                                <a asp-controller="Home" asp-action="Index" class="text-blue-600 font-bold hover:underline">
                                    Inicia Sesión
                                </a>
                            </p>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Función para ver/ocultar contraseña
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.innerText = "visibility";
            } else {
                input.type = "password";
                icon.innerText = "visibility_off";
            }
        }

        // Validación de coincidencia de contraseñas
        const form = document.getElementById('registerForm');
        const pass = document.getElementById('pass');
        const confirm = document.getElementById('confirmPass');
        const errorSpan = document.getElementById('errorConfirm');

        form.addEventListener('submit', function (e) {
            if (pass.value !== confirm.value) {
                e.preventDefault(); // BLOQUEA EL ENVÍO
                errorSpan.innerText = " Las contraseñas no coinciden";
                confirm.classList.add('border-red-500', 'ring-2', 'ring-red-200');
            } else {
                errorSpan.innerText = "";
                confirm.classList.remove('border-red-500');
            }
        });
    </script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>