@model IEnumerable<PETADOPCION_FINAL.Models.Usuario>

@{
    
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Gestión de Usuarios - PetParadise</title>
</head>

<body class="bg-slate-50 min-h-screen font-sans">

    <header class="bg-[#2F5975] shadow-lg text-white p-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <span class="text-xl font-bold tracking-widest">PETPARADISE ADMIN</span>
            <nav class="space-x-4">
                <a href="#" class="hover:text-blue-200">Inicio</a>
                <a href="#" class="hover:text-blue-200">Volver al sitio</a>
            </nav>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-12">

        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-extrabold text-slate-800">Listado de Usuarios</h1>
            <a asp-action="Create"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-semibold shadow-lg transition duration-300">
                + Crear Usuario
            </a>
        </div>

        @* Div con overflow-x-auto para que sea responsive *@
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[1000px]">
                    <thead class="bg-slate-100 border-b border-slate-200">
                        <tr>
                            <th class="px-6 py-4 font-bold text-slate-700">Nombre</th>
                            <th class="px-6 py-4 font-bold text-slate-700">Email</th>
                            <th class="px-6 py-4 font-bold text-slate-700">Teléfono</th>

                            @* LAS NUEVAS COLUMNAS CON NOMBRES CLAROS *@
                            <th class="px-4 py-4 font-bold text-slate-700 text-center">Mascotas Publicadas</th>
                            <th class="px-4 py-4 font-bold text-slate-700 text-center">Solicitudes Recibidas</th>
                            <th class="px-4 py-4 font-bold text-slate-700 text-center">Solicitudes Enviadas</th>
                            <th class="px-4 py-4 font-bold text-slate-700 text-center">Mascotas Adoptadas</th>

                            <th class="px-6 py-4 font-bold text-slate-700">Rol</th>
                            <th class="px-6 py-4 font-bold text-slate-700 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-blue-50/50 transition">
                                <td class="px-6 py-4 text-slate-600 font-medium whitespace-nowrap">@item.Nombre @item.Apellido</td>
                                <td class="px-6 py-4 text-slate-600 whitespace-nowrap">@item.Email</td>
                                <td class="px-6 py-4 text-slate-600 whitespace-nowrap">@item.Telefono</td>

                                @* DATOS AGREGADOS *@
                                <td class="px-4 py-4 text-center font-bold text-blue-600">
                                    @item.Mascota.Count()
                                </td>
                                <td class="px-4 py-4 text-center font-bold text-purple-600">
                                    @item.Mascota.Sum(m => m.SolicitudesAdopcions.Count())
                                </td>
                                <td class="px-4 py-4 text-center font-bold text-amber-600">
                                    @item.SolicitudesAdopcions.Count()
                                </td>
                                <td class="px-4 py-4 text-center font-bold text-emerald-600">
                                    @item.Adopciones.Count()
                                </td>

                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold border border-blue-200">
                                        @item.IdRolNavigation?.NombreRol
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center space-x-3 whitespace-nowrap">
                                    <a asp-action="Edit" asp-route-id="@item.IdUsuario" class="text-blue-600 hover:text-blue-900 font-semibold transition">Editar</a>
                                    <a asp-action="Details" asp-route-id="@item.IdUsuario" class="text-slate-500 hover:text-slate-800 font-semibold transition">Detalles</a>
                                    <a asp-action="Delete" asp-route-id="@item.IdUsuario" class="text-red-500 hover:text-red-700 font-semibold transition">Eliminar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 text-sm text-slate-500 flex justify-between items-center">
                <span>Mostrando @Model.Count() usuarios registrados en el sistema.</span>
                <span class="md:hidden text-xs font-bold text-blue-500">Desliza para ver más →</span>
            </div>
        </div>
    </main>

    <footer class="text-center py-6 text-slate-400 text-sm">
        © 2026 PetParadise Admin Dashboard
    </footer>

</body>
</html>