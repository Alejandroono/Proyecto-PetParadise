@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <title>Recuperar Contraseña - PetParadise</title>
</head>

<body class="bg-gradient-to-br from-[#2F5975] via-slate-800 to-slate-900 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-3xl shadow-2xl w-full max-w-md text-white font-sans">

        <div class="text-center mb-8">
            <div class="bg-white/20 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="material-icons text-3xl text-blue-300">lock_reset</span>
            </div>
            <h2 class="text-2xl font-black uppercase tracking-tighter">Restablecer</h2>
            <p class="text-blue-200 text-[10px] font-bold uppercase tracking-[0.2em] mt-2">Seguridad PetParadise</p>
        </div>

        @* SECCIÓN DE ALERTAS *@
        @if (TempData["Mensaje"] != null)
        {
            <div class="mb-6 bg-emerald-500/20 border border-emerald-500/50 text-emerald-100 p-4 rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2">
                <span class="material-icons text-sm">verified</span> @TempData["Mensaje"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-6 bg-red-500/20 border border-red-500/50 text-red-100 p-4 rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2">
                <span class="material-icons text-sm">error_outline</span> @TempData["Error"]
            </div>
        }

        <form asp-controller="Home" asp-action="contrasena" method="post" class="space-y-6">
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-blue-200 mb-2 ml-1">Correo Registrado</label>
                <div class="relative">
                    <span class="material-icons absolute left-4 top-1/2 -translate-y-1/2 text-white/40 text-lg">email</span>
                    <input name="email" type="email" required
                           class="w-full bg-white/5 border border-white/10 rounded-xl pl-12 pr-4 py-4 focus:ring-2 focus:ring-blue-400 outline-none transition font-bold"
                           placeholder="ejemplo@correo.com" />
                </div>
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-500 text-white py-4 rounded-xl font-black uppercase tracking-widest text-xs transition transform active:scale-95 shadow-lg flex items-center justify-center gap-2">
                <span class="material-icons text-sm">send</span> Enviar Instrucciones
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-white/10">
            <a asp-controller="Home" asp-action="Index" class="text-blue-300 hover:text-white text-[10px] font-black uppercase tracking-[0.3em] transition flex items-center justify-center gap-2">
                <span class="material-icons text-sm">arrow_back</span> Volver al Inicio
            </a>
        </div>
    </div>

</body>
</html>