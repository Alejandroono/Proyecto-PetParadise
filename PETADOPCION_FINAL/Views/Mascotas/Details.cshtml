@model PETADOPCION_FINAL.Models.Mascota

@{
    ViewData["Title"] = "Detalles de " + Model.Nombre;

    // Cálculo de edad para mostrarla elegante
    int totalDias = Model.Edad ?? 0;
    int anos = totalDias / 365;
    int meses = (totalDias % 365) / 30;
    int dias = (totalDias % 365) % 30;
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        @* Encabezado con color según el estado *@
        <div class="card-header @(Model.EstadoAdopcion == "Adoptado" ? "bg-secondary" : "bg-primary") text-white p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold"><i class="fas fa-info-circle"></i> @Model.Nombre</h2>
                 
                </div>
                <div class="text-end">
                    <h4 class="mb-0">@Model.EstadoAdopcion</h4>
                    <small class="opacity-75">Publicado el: @Model.FechaPublicacion?.ToString("dd/MM/yyyy")</small>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row">
                @* Columna Izquierda: Información Básica *@
                <div class="col-md-6 border-end">
                    <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fas fa-paw"></i> Información Básica</h5>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Edad:</div>
                        <div class="col-sm-8 text-dark">
                            @(anos > 0 ? anos + (anos == 1 ? " Año " : " Años ") : "")
                            @(meses > 0 ? meses + (meses == 1 ? " Mes " : " Meses ") : "")
                            @(dias > 0 || (anos == 0 && meses == 0) ? dias + (dias == 1 ? " Día" : " Días") : "")
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Tipo:</div>
                        <div class="col-sm-8 text-dark">@Model.Tipo</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Raza:</div>
                        <div class="col-sm-8 text-dark">@Model.Raza</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Sexo:</div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.Sexo == "Macho" ? "bg-info" : "bg-danger")">
                                <i class="fas @(Model.Sexo == "Macho" ? "fa-mars" : "fa-venus")"></i> @Model.Sexo
                            </span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Ubicación:</div>
                        <div class="col-sm-8 text-dark"><i class="fas fa-map-marker-alt text-danger"></i> @Model.Ubicacion</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Salud:</div>
                        <div class="col-sm-8"><span class="text-success fw-bold">@Model.EstadoSalud</span></div>
                    </div>
                </div>

                @* Columna Derecha: Descripción y Publicador *@
                <div class="col-md-6 ps-4">
                    <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fas fa-history"></i> Historia y Detalles</h5>
                    <p class="text-dark bg-light p-3 rounded-3 shadow-sm" style="min-height: 150px; white-space: pre-line;">
                        @Model.Descripcion
                    </p>

                    <div class="card bg-light border-0 mt-4">
                        <div class="card-body d-flex align-items-center">
                            <div class="me-3">
                                <i class="fas fa-user-circle fa-3x text-primary"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">Publicado por:</h6>
                                <p class="mb-0 text-muted">@Model.IdUsuarioPublicadorNavigation?.Nombre</p>
                                @* Nota: Asegúrate de tener el .Include(m => m.IdUsuarioPublicadorNavigation) en el controlador *@
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Pie de página con acciones *@
        <div class="card-footer bg-white p-3 border-top-0 d-flex justify-content-between">
            <button type="button" onclick="history.back()" class="btn btn-outline-secondary px-4">
                <i class="fas fa-arrow-left"></i> Volver
            </button>

            <div class="gap-2 d-flex">
                @if (Model.EstadoAdopcion != "Adoptado")
                {
                    <a asp-action="Edit" asp-route-id="@Model.IdMascota" class="btn btn-warning px-4">
                        <i class="fas fa-edit"></i> Editar Información
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary px-4" disabled>
                        <i class="fas fa-lock"></i> Mascota Adoptada
                    </button>
                }
            </div>
        </div>
    </div>
</div>