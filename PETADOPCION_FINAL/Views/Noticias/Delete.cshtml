@model PETADOPCION_FINAL.Models.Noticia

@{
    ViewData["Title"] = "Eliminar Noticia";
   
}

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

<body class="bg-gray-100 font-sans py-10 px-4">

    <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-200">

            @* Encabezado de Advertencia *@
            <div class="bg-red-500 p-8 text-white flex items-center justify-between">
                <div>
                    <h2 class="text-3xl font-black italic tracking-tighter flex items-center gap-3 text-white">
                        <span class="material-icons text-white text-4xl">warning</span>
                        ¿ELIMINAR NOTICIA?
                    </h2>
                    <p class="text-red-100 text-[10px] mt-1 uppercase tracking-[0.2em] font-bold opacity-80 text-white">Esta acción no se puede deshacer</p>
                </div>
                <span class="material-icons text-7xl opacity-20 hidden sm:block text-white">delete_forever</span>
            </div>

            <div class="p-8 md:p-12">
                @* Card de previsualización de lo que se va a borrar *@
                <div class="bg-slate-50 rounded-3xl p-6 border border-slate-200 mb-8">
                    <div class="flex flex-col md:flex-row gap-6">
                        @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                        {
                            <img src="@Model.ImagenUrl" class="w-full md:w-40 h-40 object-cover rounded-2xl shadow-md" />
                        }
                        <div class="flex-1">
                            <span class="text-[10px] font-black text-red-500 uppercase tracking-widest">Confirmar contenido:</span>
                            <h3 class="text-2xl font-bold text-slate-800 leading-tight mb-2">@Model.Titulo</h3>
                            <p class="text-slate-500 text-sm line-clamp-3">@Model.Subtitulo</p>

                            <div class="mt-4 flex items-center gap-2 text-slate-400 text-xs font-bold uppercase">
                                <span class="material-icons text-sm">calendar_today</span>
                                @(Model.FechaPublicacion.HasValue? Model.FechaPublicacion.Value.ToString("dd MMM yyyy") : "Sin fecha")
                                <span class="mx-2">•</span>
                                <span class="material-icons text-sm">person</span>
                                @Model.Usuario?.Apellido
                            </div>
                        </div>
                    </div>
                </div>

                @* Formulario de eliminación *@
                <form asp-action="Delete">
                    <input type="hidden" asp-for="IdNoticia" />

                    <div class="flex flex-col sm:flex-row gap-4">
                        @* Botón de ELIMINAR (POST) *@
                        <button type="submit" class="flex-[2] bg-red-600 hover:bg-red-700 text-white font-black py-5 rounded-2xl shadow-xl shadow-red-200 transition-all active:scale-95 uppercase tracking-widest text-sm flex justify-center items-center gap-3">
                            <span class="material-icons">delete_outline</span>
                            Confirmar Eliminación
                        </button>

                        @* Botón de CANCELAR (Regresa 1 paso atrás) *@
                        <a href="javascript:void(0);" onclick="window.history.go(-1);"
                           class="flex-1 bg-white border-2 border-slate-200 text-slate-500 font-black py-5 rounded-2xl text-center hover:bg-slate-50 transition-all uppercase tracking-widest text-sm flex justify-center items-center gap-2">
                            <span class="material-icons">close</span>
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>

        </div>

        @* Mensaje de ayuda *@
        <p class="text-center text-slate-400 text-[10px] font-bold uppercase tracking-[0.3em] mt-8">
            PetAdopción Management System Suite 2026
        </p>
    </div>

</body>