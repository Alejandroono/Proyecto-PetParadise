@model PETADOPCION_FINAL.Models.Noticia

@{
    ViewData["Title"] = "Crear Noticia";
    
}

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

<body class="bg-gray-100 font-sans py-10 px-4">

    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-200">

            <div class="bg-[#5CA9DD] p-8 text-white flex items-center justify-between">
                <div>
                    <h2 class="text-3xl font-black italic tracking-tighter flex items-center gap-3">
                        <span class="material-icons text-white text-4xl">add_circle</span>
                        NUEVA NOTICIA
                    </h2>
                    <p class="text-blue-50 text-[10px] mt-1 uppercase tracking-[0.2em] font-bold opacity-80">Panel de Administración</p>
                </div>
                <span class="material-icons text-7xl opacity-20 hidden sm:block">newspaper</span>
            </div>

            <form asp-action="Create" enctype="multipart/form-data" class="p-8 md:p-12 space-y-8">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

                    <div class="space-y-6">
                        <h3 class="text-slate-800 font-black text-lg flex items-center gap-2 border-b pb-2">
                            <span class="material-icons text-[#5CA9DD]">edit</span>
                            Redacción
                        </h3>

                        <div>
                            <label asp-for="Titulo" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">Título</label>
                            <input asp-for="Titulo" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-bold text-slate-700" placeholder="Título de la noticia" />
                            <span asp-validation-for="Titulo" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>

                        <div>
                            <label asp-for="Subtitulo" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">Resumen (Slider)</label>
                            <input asp-for="Subtitulo" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-medium text-slate-600" placeholder="Texto breve para el carrusel" />
                            <span asp-validation-for="Subtitulo" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>

                        <div>
                            <label asp-for="Contenido" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">Contenido Detallado</label>
                            <textarea asp-for="Contenido" rows="6"
                                      class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-medium text-slate-600 resize-none"
                                      placeholder="Escribe aquí toda la noticia completa..."></textarea>
                            <span asp-validation-for="Contenido" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <h3 class="text-slate-800 font-black text-lg flex items-center gap-2 border-b pb-2">
                            <span class="material-icons text-[#5CA9DD]">attachment</span>
                            Multimedia y Link
                        </h3>

                        <div>
                            <label asp-for="EnlaceUrl" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">URL del Botón</label>
                            <input asp-for="EnlaceUrl" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-medium text-slate-500" placeholder="https://..." />
                            <span asp-validation-for="EnlaceUrl" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>

                        <div>
                            <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1 tracking-widest">Imagen Principal</label>
                            <div class="relative group">
                                <input type="file" name="archivoImagen" id="archivoImagen" accept="image/*" class="hidden" required/>
                                <label for="archivoImagen" class="flex items-center justify-between w-full px-5 py-5 bg-slate-800 hover:bg-slate-700 text-white rounded-2xl cursor-pointer transition-all shadow-lg active:scale-95">
                                    <span id="file-label" class="text-xs font-black uppercase">Agregar Imagen</span>
                                    <span class="material-icons text-[#5CA9DD]">add_a_photo</span>
                                </label>
                            </div>
                            <span class="text-red-500 text-[10px] font-bold mt-2 ml-1 block" data-valmsg-for="archivoImagen" data-valmsg-replace="true"></span>
                        </div>

                    </div>
                </div>

                <div class="pt-8 flex flex-col sm:flex-row gap-4 border-t">
                    <button type="submit" class="flex-[2] bg-[#5CA9DD] hover:bg-blue-600 text-white font-black py-5 rounded-2xl shadow-xl transition-all active:scale-95 uppercase tracking-widest text-sm flex justify-center items-center gap-3">
                        <span class="material-icons">publish</span>
                        Publicar Ahora
                    </button>
                    <a asp-action="Index" class="flex-1 bg-white border-2 border-slate-200 text-slate-400 font-black py-5 rounded-2xl text-center hover:bg-slate-50 transition-all uppercase tracking-widest text-sm flex justify-center items-center gap-2">
                        <span class="material-icons">close</span>
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('archivoImagen').onchange = function () {
            const label = document.getElementById('file-label');
            if(this.files[0]) {
                label.innerText = this.files[0].name;
                label.classList.add('text-blue-300');
            }
        };
    </script>

</body>