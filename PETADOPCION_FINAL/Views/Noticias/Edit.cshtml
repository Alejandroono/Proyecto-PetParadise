@model PETADOPCION_FINAL.Models.Noticia

@{
    ViewData["Title"] = "Editar Noticia";
}

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

<body class="bg-gray-100 font-sans py-10 px-4">

    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-200">

            @* Encabezado con el estilo que ya manejas *@
            <div class="bg-[#5CA9DD] p-8 text-white flex items-center justify-between">
                <div>
                    <h2 class="text-3xl font-black italic tracking-tighter flex items-center gap-3">
                        <span class="material-icons text-white text-4xl">edit</span>
                        EDITAR NOTICIA
                    </h2>
                    <p class="text-blue-50 text-[10px] mt-1 uppercase tracking-[0.2em] font-bold opacity-80">ID de Noticia: @Model.IdNoticia</p>
                </div>
                <span class="material-icons text-7xl opacity-20 hidden sm:block">newspaper</span>
            </div>

            @* Formulario con enctype para subir la nueva imagen *@
            <form asp-action="Edit" enctype="multipart/form-data" class="p-8 md:p-12 space-y-8">

                @* Campos ocultos necesarios *@
                <input type="hidden" asp-for="IdNoticia" />
                <input type="hidden" asp-for="ImagenUrl" />
                <input type="hidden" asp-for="IdUsuarioPublicador" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

                    @* Columna de Redacción *@
                    <div class="space-y-6">
                        <h3 class="text-slate-800 font-black text-lg flex items-center gap-2 border-b pb-2">
                            <span class="material-icons text-[#5CA9DD]">subject</span>
                            Contenido
                        </h3>

                        <div>
                            <label asp-for="Titulo" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">Título</label>
                            <input asp-for="Titulo" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-bold text-slate-700" />
                            @* VALIDACIÓN TÍTULO *@
                            <span asp-validation-for="Titulo" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>

                        <div>
                            <label asp-for="Subtitulo" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">Resumen (Slider)</label>
                            <input asp-for="Subtitulo" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-medium text-slate-600" />
                            @* VALIDACIÓN SUBTÍTULO *@
                            <span asp-validation-for="Subtitulo" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>

                        <div>
                            <label asp-for="Contenido" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">Contenido Detallado</label>
                            <textarea asp-for="Contenido" rows="6"
                                      class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-medium text-slate-600 resize-none"></textarea>
                            @* VALIDACIÓN CONTENIDO *@
                            <span asp-validation-for="Contenido" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>
                    </div>

                    @* Columna Multimedia *@
                    <div class="space-y-6">
                        <h3 class="text-slate-800 font-black text-lg flex items-center gap-2 border-b pb-2">
                            <span class="material-icons text-[#5CA9DD]">image</span>
                            Imagen y Enlace
                        </h3>

                        @* Vista previa de la imagen actual *@
                        <div class="bg-slate-50 p-4 rounded-2xl border border-dashed border-slate-300 text-center">
                            <p class="text-[9px] font-black text-slate-400 uppercase mb-2">Imagen Actual</p>
                            <img src="@Model.ImagenUrl" class="h-32 mx-auto rounded-lg shadow-md mb-2 object-cover" alt="Previsualización" />
                        </div>

                        <div>
                            <label class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1 tracking-widest">Actualizar Imagen (Opcional)</label>
                            <div class="relative group">
                                <input type="file" name="archivoImagen" id="archivoImagen" accept="image/*" class="hidden" />
                                <label for="archivoImagen" class="flex items-center justify-between w-full px-5 py-5 bg-slate-800 hover:bg-slate-700 text-white rounded-2xl cursor-pointer transition-all shadow-lg active:scale-95">
                                    <span id="file-label" class="text-xs font-black uppercase">Cambiar Imagen</span>
                                    <span class="material-icons text-[#5CA9DD]">cloud_upload</span>
                                </label>
                            </div>
                            @* Aquí no va span de validación obligatorio porque es opcional en edición *@
                        </div>

                        <div>
                            <label asp-for="EnlaceUrl" class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-1">URL del Botón</label>
                            <input asp-for="EnlaceUrl" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-[#5CA9DD] outline-none font-medium text-slate-500" />
                            @* VALIDACIÓN ENLACE *@
                            <span asp-validation-for="EnlaceUrl" class="text-red-500 text-[10px] font-bold mt-1 ml-1 block"></span>
                        </div>

                        <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-200">
                            <input type="checkbox" asp-for="Activo" class="w-5 h-5 accent-[#5CA9DD]" />
                            <label asp-for="Activo" class="text-xs font-black uppercase text-slate-600">Noticia Visible/Activa</label>
                        </div>
                    </div>
                </div>

                @* Botones de Acción *@
                <div class="pt-8 flex flex-col sm:flex-row gap-4 border-t">
                    <button type="submit" class="flex-[2] bg-[#5CA9DD] hover:bg-blue-600 text-white font-black py-5 rounded-2xl shadow-xl transition-all active:scale-95 uppercase tracking-widest text-sm flex justify-center items-center gap-3">
                        <span class="material-icons">save</span>
                        Guardar Cambios
                    </button>

                    <a asp-action="Index" class="flex-1 bg-white border-2 border-slate-200 text-slate-400 font-black py-5 rounded-2xl text-center hover:bg-slate-50 transition-all uppercase tracking-widest text-sm flex justify-center items-center gap-2">
                        <span class="material-icons">arrow_back</span>
                        Volver
                    </a>
                </div>
            </form>

            @section Scripts {
                @{
                    await Html.RenderPartialAsync("_ValidationScriptsPartial");
                }

                <script>
                    // Actualizar el nombre del archivo en el label al seleccionar uno nuevo
                    document.getElementById('archivoImagen').onchange = function () {
                        if(this.files.length > 0) {
                            document.getElementById('file-label').innerHTML = this.files[0].name;
                        }
                    };
                </script>
            }
        </div>
    </div>

    <script>
        // Script para que el nombre del archivo se vea al seleccionarlo
        document.getElementById('archivoImagen').onchange = function () {
            const label = document.getElementById('file-label');
            if(this.files[0]) {
                label.innerText = this.files[0].name;
                label.classList.add('text-blue-300');
            }
        };
    </script>

</body>